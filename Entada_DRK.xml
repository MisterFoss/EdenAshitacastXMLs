 

<ashitacast>
    <settings> <!--Contains settings specific to this xml, must be set to true/false to override default-->
        <buffupdate>true</buffupdate> <!--Determines if your idlegear will be parsed when you gain/lose a buff. Default: TRUE -->
        <statusupdate>true</statusupdate> <!--Determines if your idlegear will be parsed when you change status(stand/rest/engage/etc).  Default: TRUE -->
        <hpupdate>false</hpupdate> <!--Determines if your idlegear will be parsed when your HP % changes.  Default: TRUE -->
        <autoupdate>true</autoupdate> <!--Determines if your idlegear will be parsed on outgoing status updates(roughly every 350ms).  Default: TRUE-->
    </settings>
    <variables>
        <var name="Evasion">0</var>
        <var name="PhysicalDefense">0</var>
        <var name="MagicDefense">0</var>
        <var name="FireResist">0</var>
        <var name="LightningResist">0</var>
        <var name="Acc">0</var>
    </variables>
    <init>
        <command delay="1500">/echo ****** Initiating Warrior AshitaCast, ENJOY! ******</command>
        <command delay="1600">/echo Job is %p_job.</command>
        <command delay="1700">/echo Macro-book $macrobook, Page $macropage.</command>
        <command delay="2000">/macro book $macrobook</command>
        <command delay="3000">/macro set $macropage</command>		
        <command delay="3200">/gl blink</command>
		<command delay="3400">/Addon reload equipviewer</command>
<!-- This codeblock will automatically change your macro book/page/lockstyle according to the job and subjob list below -->
<!-- Change the below variable subjob abbreviations according to the subjobs you use with this profile. -->		
        <if p_mainjob="WAR"><setvar name="macrobook" value="1" /></if>
        <if p_subjob="NIN"><setvar name="macropage" value="1" /></if>
        <if p_subjob="SAM"><setvar name="macropage" value="1" /></if>
<!-- Delete next line if you don't use keybinds -->
		<!-- <command delay="5000">/exec WAR_keybinds</command> -->
    </init>
	
    <sets>
	
	

	
<!-- Default Idle Set when out of combat -->
        <set name="Idle">
			<head>Walahra Turban</head>
			<body>Hauberk +1</body>
			<hands>Darksteel Mittens</hands>
			<legs>Ryl.Kgt. Breeches</legs>
			<feet>Homam Gambieras</feet>
			<neck>Parade Gorget</neck>
			<waist>Life Belt</waist>
			<ear1>Coral Earring</ear1>
			<ear2>Coral Earring</ear2>
			<ring1>Ruby Ring</ring1>
			<ring2>Rajas Ring</ring2>
			<back>Lamia Mantle</back>
        </set>
		
<!-- Town Set, When in Windurst -->
        <set name="Town">
            <head>Walahra Turban</head>
            <body>Federation Aketon</body>
        </set>

<!-- Default TP Set -->
        <set name="TP">
			<head>Walahra Turban</head>
			<body>Hauberk +1</body>
			<hands>Dusk Gloves</hands>
			<legs>Ryl.Kgt. Breeches</legs>
			<feet>Homam Gambieras</feet>
			<neck>Chivalrous Chain</neck>
			<waist>Swift Belt</waist>   
			<ear1>Abyssal Earring</ear1>
			<ear2>Coral Earring</ear2>
			<ring1>Sniper's Ring</ring1>
			<ring2>Rajas Ring</ring2>
			<back>Abyss Cape</back>
        </set>
		
<!-- High Accuracy Set, /acc /acco -->
        <set name="Acc">

        </set>
		
<!-- Evasion Set, /eva /evao -->
        <set name="Evasion">

        </set>
		
<!-- PDT Set, /pdt /pdto -->
        <set name="PhysicalDefense">
        </set>
		
<!-- MDT Set, /mdt /mdto -->
        <set name="MagicDefense">
        </set>
		
<!-- Fire Resist Set for Cerberus, /fr /fro -->
        <set name="FireResist">

        </set>
		
<!-- Lightning Resist Set for Khimaira, /lr /lro -->
        <set name="LightningResist">

        </set>
		
<!-- Default WS Set -->		
        <set name="WS">
			<head>Chaos Burgeonet</head>
			<body>Hauberk +1</body>
			<hands>Black Gadlings</hands>
			<legs>Black Cuisses</legs>
			<feet>Black Sollerets</feet>
			<neck>Chivalrous Chain</neck>
			<waist>Life Belt</waist>
			<ear1>Abyssal Earring</ear1>
			<ear2>Coral Earring</ear2>
			<ring1>Ruby Ring</ring1>
			<ring2>Rajas Ring</ring2>
			<back>Forager's Mantle</back>
        </set>
		
<!-- Snaphot set for Ranged Attacks -->
		<set name="Preshot">
		</set>
		
<!-- Ranged Attack Set -->		
		<set name="Ranged">
        	<ring1>Bone Ring +1</ring1>
			<ring2>Bone Ring +1</ring2>
		</set>
		
<!-- Haste Set for Magic Recast -->
		<set name="Haste">
			<head>Walahra Turban</head>
			<hands>Dusk Gloves</hands>
			<feet>Homam Gambieras</feet>
            <waist>Swift Belt</waist>
        </set>

        <set name="DarkMagic" baseset="Haste">
